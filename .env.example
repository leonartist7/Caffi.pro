# ============================================================================
# aro platform — environment keys (ARCHITECTURE.md §5)
# Copy to .env.local for local dev. NEVER commit real values: .env* is
# git-ignored (a service key was burned in git history once — rotate it!).
# "Phase" = first phase that needs the key. Missing keys must surface as a
# visible "STUBBED — needs <key>" badge, never a faked connection.
# ============================================================================

# --- Supabase (Phase 2) -----------------------------------------------------
# Live project: aro-platform (jjgccfrwjkwknyjtbtxa), created 2026-07-10.
# The original Caffi.pro project (ugppbaavzevmdkblniim) was paused >90 days
# and is unrecoverable — this is a fresh project, schema/RLS/seed applied.
# Real URL + anon key are in docs/plans/HANDOFF-live-bringup.md (both are
# public-safe, meant for client code). Service-role key is NOT retrievable
# via the Supabase MCP connector by design — get it from Dashboard →
# Settings → API → service_role, then set it below AND in Vercel envs.
NEXT_PUBLIC_SUPABASE_URL=https://jjgccfrwjkwknyjtbtxa.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never NEXT_PUBLIC_, never imported outside lib/supabase-admin.ts.
SUPABASE_SERVICE_ROLE_KEY=

# --- App (Phase 2) ------------------------------------------------------------
# Canonical origin for links in emails/invites (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Sentry (Phase 2) ---------------------------------------------------------
# sentry.io → Project → Client Keys (DSN). Both point at the same DSN.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Feature flags (Phase 2) ---------------------------------------------------
# DEMO_MODE=true marks the venue data as resettable demo content.
DEMO_MODE=false
# Legacy shop/ordering PWA is parked until the ordering phase. Keep false.
ORDERING_ENABLED=false

# --- OpenAI (Phase 4 — AI drafts via lib/ai.ts only) ---------------------------
OPENAI_API_KEY=

# --- Resend (Phase 4 — email nudges + weekly digest) ---------------------------
RESEND_API_KEY=

# --- Twilio (Phase 4 — SMS nudges, STOP handling) ------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Stripe Billing (Phase 4 — $149/mo, first month free) ----------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Wallet passes (Phase 3) ----------------------------------------------------
# Apple: PassKit certificate exported as base64 .p12 + its password.
APPLE_PASS_CERT_P12_BASE64=
APPLE_PASS_CERT_PASSWORD=
APPLE_TEAM_ID=
APPLE_PASS_TYPE_ID=
# Google Wallet issuer + service-account JSON (single line).
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SA_KEY_JSON=

# --- Leads webhook (Plan 5) ------------------------------------------------------
# Shared secret for the AURA -> platform lead forward. Same value in BOTH
# repos' envs (AURA sends it as x-aro-leads-secret; /api/leads verifies).
LEADS_WEBHOOK_SECRET=

# --- Cron protection (Phase 4) ---------------------------------------------------
# Random secret; Vercel Cron sends it as Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=
