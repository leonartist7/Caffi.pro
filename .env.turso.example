# Turso Database Configuration
# Copy this file to .env.local and fill in your Turso credentials

# Turso Database URL
# Get this from: turso db show <database-name>
TURSO_DATABASE_URL=libsql://your-database.turso.io

# Turso Auth Token
# Get this from: turso db tokens create <database-name>
TURSO_AUTH_TOKEN=your-auth-token-here

# Optional: For local development, you can use a local SQLite file
# TURSO_DATABASE_URL=file:./local.db
# TURSO_AUTH_TOKEN=
